### CONFIG ###
# command = /opt/homebrew/bin/fish
shell-integration = fish
copy-on-select = clipboard
link-url = true

### APPEARANCE ###
theme = "Catppuccin Mocha"
cursor-style = underline
cursor-style-blink = false
cursor-color = cyan

window-padding-x = 4
window-padding-y = 4

background-opacity = 0.9
background-blur = true

### KEY BINDINGS ###

keybind = super+shift+p=toggle_command_palette
# This is only supported on Linux and when the system's libadwaita version is 1.4 or newer. The current libadwaita version can be found by running ghostty +version.
keybind = super+p=toggle_tab_overview

 # TAB NAVIGATION
keybind = super+alt+arrow_right=next_tab
keybind = super+alt+arrow_left=previous_tab

# SPLIT NAVIGATION
keybind = ctrl+shift+arrow_left=goto_split:left
keybind = ctrl+shift+arrow_right=goto_split:right
keybind = ctrl+shift+arrow_up=goto_split:up
keybind = ctrl+shift+arrow_down=goto_split:down

keybind = super+backslash=new_split:right
keybind = super+shift+backslash=new_split:down