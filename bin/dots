#!/usr/bin/env bash

# `dot` handles installation, updates, things like that. Run it periodically
# to make sure you're on the latest and greatest.
set -o errexit  # abort on nonzero exitstatus
set -o nounset  # abort on unbound variable
set -o pipefail # don't hide errors within pipes
# set -o xtrace   # print execution commands

cd $DOTS

# update brew itself
brew update

echo "🔴 Running brew bundle for Brewfile 🔴"
# install/update packages from Brewfile
brew bundle

# install/update packages from Brewfile.local if it exists
if [ -f "$DOTS/Brewfile.local" ]; then
    echo "🟢 Running brew bundle for Brewfile.local 🟢"
    brew bundle --file "$DOTS/Brewfile.local"
fi

# upgrade all packages
brew upgrade
# update all casks. Ignore anki, beyond 25.02 it breaks Keyboard Maestro key overrides
brew list --cask | xargs brew upgrade

# cleanup and make sure nothing is broken, symlinks, etc
brew cleanup
brew doctor
